# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL — create the database yourself, e.g.:
#   createdb citywish
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/citywish

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Google APIs — leave USE_MOCK_PLACES=true to run without any Google Cloud
# setup at all. The mock service returns realistic fake places/geocoding
# results so the app works end to end with zero external cost or keys.
#
# To go live: set USE_MOCK_PLACES=false and provide real keys from a Google
# Cloud project with the Places API, Maps JavaScript API, and Geocoding API
# enabled. See ../README.md for exact setup steps.
USE_MOCK_PLACES=true
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=
