# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL — create the database yourself, e.g.:
#   createdb citypulse
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/citypulse

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Places data — leave USE_MOCK_PLACES=true to run without any external setup
# at all. The mock service returns realistic fake places/geocoding results so
# the app works end to end with zero external cost or keys.
#
# To go live (free): set USE_MOCK_PLACES=false and provide a Foursquare API
# key. Foursquare's free tier (10,000 calls/month) powers nearby search,
# geocoding, and autocomplete — real business names/addresses/categories, but
# no ratings/reviews/photos (those are a paid-only tier on Foursquare, so
# they're intentionally left out rather than faked).
# Get a free key at https://location.foursquare.com/developer/
USE_MOCK_PLACES=true
FOURSQUARE_API_KEY=
